{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/nutrislice/**",
        "function": "proxyNutrislice"
      },
      {
        "source": "/privacy",
        "destination": "/privacy.html"
      }
    ]
  }
}